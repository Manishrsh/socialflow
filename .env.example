# Database Configuration
# PostgreSQL connection string for Neon or your PostgreSQL instance
DATABASE_URL=postgresql://user:password@host:5432/warechat_pro

# Authentication Configuration
# Minimum 32 characters, use strong random string in production
STACK_SECRET_SERVER_KEY=your-super-secret-key-minimum-32-characters-long

# n8n Workflow Automation
# URL of your n8n instance
N8N_API_URL=http://localhost:5678/api/v1

# API key for n8n authentication
N8N_API_KEY=your-n8n-api-key

# Webhook URL that n8n will POST to (must be publicly accessible in production)
N8N_WEBHOOK_URL=http://localhost:3000/api/n8n/webhook

# Own BSP mode
OWN_BSP_NAME=WareChat Own BSP
OWN_BSP_MODE=true
OWN_BSP_AUTO_PROCESS=true
OWN_BSP_EXECUTION_MODE=meta
OWN_BSP_PROVIDER_SEND_URL=
OWN_BSP_PROVIDER_TIMEOUT_MS=15000

# Optional legacy external provider integration (deprecated in Own BSP mode)
WPBOX_BASE_URL=https://chat.leminai.com/api/wpbox
WPBOX_TOKEN=your-wpbox-token
WPBOX_USER_ID=1880
WPBOX_TIMEOUT_MS=60000

# Shared token for inbound BSP webhooks
# Providers should send this in `x-webhook-token` header.
BSP_WEBHOOK_TOKEN=manish-bsp-webhook-token
INTERNAL_EXECUTION_TOKEN=your-internal-execution-token

# Optional: default provider for /api/webhooks/bsp/{workspaceId}
BSP_DEFAULT_PROVIDER=generic

# Application Configuration
# Base URL of your application (used for redirects and links)
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Meta WhatsApp Embedded Signup URL (frontend connect button)
NEXT_PUBLIC_WHATSAPP_EMBEDDED_SIGNUP_URL=https://business.facebook.com/messaging/whatsapp/onboard/?app_id=your_app_id&config_id=your_config_id&extras=%7B%22sessionInfoVersion%22%3A%223%22%2C%22version%22%3A%22v3%22%7D

# Meta app core configuration (recommended)
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret
META_CONFIG_ID=your_embedded_signup_config_id
META_REDIRECT_URI=https://your-domain.com/api/integrations/meta/callback
META_BUSINESS_ID=your_meta_business_id
META_WHATSAPP_PHONE_NUMBER_ID=your_whatsapp_phone_number_id
META_WHATSAPP_ACCESS_TOKEN=your_whatsapp_access_token

# Instagram connect URL (frontend connect button)
NEXT_PUBLIC_INSTAGRAM_CONNECT_URL=https://www.facebook.com/v23.0/dialog/oauth?client_id=your_meta_app_id&redirect_uri=your_redirect_uri&scope=instagram_manage_messages,pages_manage_metadata&response_type=code

# Meta webhook verification token (used by hub.challenge verification)
META_WEBHOOK_VERIFY_TOKEN=your-meta-webhook-verify-token

# Instagram outbound messaging (Meta Graph API)
INSTAGRAM_GRAPH_API_VERSION=v23.0
INSTAGRAM_BUSINESS_ACCOUNT_ID=your_instagram_business_account_id
INSTAGRAM_ACCESS_TOKEN=your_meta_page_or_instagram_access_token
INSTAGRAM_TIMEOUT_MS=30000

# Node environment
NODE_ENV=development

# Optional: Stack Auth Configuration (if using Stack authentication)
NEXT_PUBLIC_STACK_PROJECT_ID=your-stack-project-id
NEXT_PUBLIC_STACK_PUBLISHABLE_CLIENT_KEY=your-stack-publishable-key
STACK_SECRET_SERVER_KEY=your-stack-secret-key

# Optional: Email Configuration
# If you want to send emails for notifications
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# Optional: Webhook Security
# Secret for verifying webhook signatures from n8n
WEBHOOK_SIGNATURE_SECRET=your-webhook-secret

# Optional: Rate Limiting
# Maximum requests per minute per IP
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_MS=60000

# Optional: Session Configuration
SESSION_TIMEOUT_MINUTES=1440
SESSION_SECURE=true
SESSION_SAME_SITE=lax

# Optional: Logging
LOG_LEVEL=info
LOG_FORMAT=json

# Optional: Feature Flags
ENABLE_ANALYTICS=true
ENABLE_BROADCASTS=true
ENABLE_MEDIA_LIBRARY=true
ENABLE_INTEGRATIONS=true
